PORT=5001
NODE_ENV=production
PUBLIC_API_URL=https://your-backend.vercel.app/api
CORS_ORIGINS=https://your-frontend.vercel.app

MONGODB_CONNECTIONSTRING=mongodb+srv://username:password@cluster.mongodb.net/database
JWT_SECRET=replace-with-a-long-random-secret

VNPAY_TMN_CODE=your-vnpay-terminal-code
VNPAY_SECURE_SECRET=your-vnpay-secure-secret
VNPAY_RETURN_URL=https://your-frontend.vercel.app/payment/vnpay-return
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_TEST_MODE=true
VNPAY_HASH_ALGORITHM=SHA512
VNPAY_ENABLE_LOG=false

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM_NAME=MMA301 Shop
EMAIL_USE_ETHEREAL=false

GEMINI_API_KEY=your-gemini-api-key
